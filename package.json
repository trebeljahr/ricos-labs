{
  "name": "ricos-labs",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "pnpm --filter @starter/client dev",
    "build": "pnpm --filter @starter/shared run build && pnpm --filter @starter/client run build",
    "build:client": "pnpm --filter @starter/shared run build && pnpm --filter @starter/client run build",
    "test": "pnpm run test:client",
    "test:client": "pnpm --filter @starter/client run test",
    "dev:infra": "docker-compose -f docker-compose.dev.yml up -d",
    "dev:infra:stop": "docker-compose -f docker-compose.dev.yml down",
    "dev:infra:reset": "docker-compose -f docker-compose.dev.yml down -v",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "concurrently": "^9.1.0",
    "mongodb": "^6.12.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {}
}
